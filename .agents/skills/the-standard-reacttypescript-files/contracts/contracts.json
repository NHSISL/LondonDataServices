{
  "skill": "the-standard-reacttypescript-files",
  "version": "1.0.0",
  "naming": {
    "broker": "{domain}{Kind}Broker.ts",
    "broker_interface": "i{domain}{Kind}Broker.ts",
    "foundation_service": "{domain}Service.ts",
    "service_interface": "i{domain}Service.ts",
    "view_service": "{domain}ViewService.ts",
    "view_service_interface": "i{domain}ViewService.ts",
    "page": "{Domain}Page.tsx",
    "component": "{Domain}{Purpose}.tsx",
    "hook": "use{Purpose}.ts",
    "model": "{Domain}.ts or {Domain}{Purpose}.ts"
  },
  "structure": {
    "src_layout": {
      "app": ["App.tsx", "main.tsx", "routes.tsx"],
      "brokers": ["apis/", "dateTimes/", "loggings/", "navigations/", "storages/"],
      "components": ["shared/", "layouts/", "forms/", "tables/", "cards/"],
      "models": ["configurations/", "foundations/", "views/", "components/", "errors/"],
      "pages": ["home/", "dashboard/", "auth/"],
      "services": ["foundations/", "views/", "processings/", "orchestrations/"],
      "hooks": ["components/", "pages/"],
      "styles": ["bootstrap/", "global/"],
      "tests": ["fixtures/", "utilities/"]
    },
    "forbidden_file_names": ["utils", "helpers", "common", "misc", "shared"]
  },
  "extensions": {
    "component_files": ".tsx",
    "non_rendering_files": ".ts"
  }
}
