@* ✅ GOOD: .razor file contains only markup; inherits base class for all logic. *@

@inherits StudentComponentBase

<div class="student-list">
    @foreach (StudentView studentView in StudentViews)
    {
        <StudentCard
            StudentView="@studentView"
            OnClick="@(() => SelectStudentAsync(studentView))" />
    }
</div>
