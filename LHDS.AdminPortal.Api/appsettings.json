{
  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "Domain": "LondonHDS.nhs.uk",
    "TenantId": "8076439c-5b1f-4e15-91ea-a0bff0b3bf16",
    "ClientId": "2a530b09-3ec6-4846-a646-dfc835258272",
    "Scopes": "LondonHealthDataService.AdminPortal.DEV"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ApplicationInsights": {
    "ConnectionString": "override in appsettings.Development.json",
    "EnableAdaptiveSampling": false,
    "EnableDebugLogger": true
  },
  "HealthChecks": {
    "StartupDelaySeconds": 10,
    "PublishIntervalSeconds": 60,
    "IngestionTracking": {
      "Decryption": {
        "DegradedThreshold": 1440,
        "UnHealthyThreshold": 2880
      },
      "Processing": {
        "DegradedThreshold": 1440,
        "UnHealthyThreshold": 2880
      },
      "FailedToProcess": {
        "DegradedThreshold": 1440,
        "UnHealthyThreshold": 2880,
        "RetryCount": 4
      },
      "FilesReceived": {
        "DegradedThreshold": 1440,
        "UnHealthyThreshold": 2880
      },
      "IncompleteBatches": {
        "DegradedThreshold": 1440,
        "UnHealthyThreshold": 2880
      }
    },
    "ResolvedAddress": {
      "Processing": {
        "DegradedThreshold": 1440,
        "UnHealthyThreshold": 2880
      },
      "FailedToProcess": {
        "DegradedThreshold": 1440,
        "UnHealthyThreshold": 2880,
        "RetryCount": 4
      },
      "FailedToExport": {
        "DegradedThreshold": 1440,
        "UnHealthyThreshold": 2880,
        "RetryCount": 4
      },
      "AddressMatchingTime": {
        "DegradedThreshold": 1440,
        "UnHealthyThreshold": 2880
      },
      "MatchQuality": {
        "DegradedThresholdPercentage": 0.9,
        "UnhealthyThresholdPercentage":  0.8
      }
    },
    "TerminologyPolls": {
      "NotPolling": {
        "DegradedThreshold": 1440,
        "UnHealthyThreshold": 2880
      }
    },
    "OptOuts": {
      "ExpiredOptOuts": {
        "DegradedThreshold": 1440,
        "UnHealthyThreshold": 2880,
        "ExpiredAfterDays": 7,
        "LastSentExpiredAfterDays": 2
      }
    },
    "TerminologyArtifacts": {
      "FailedToProcess": {
        "DegradedThreshold": 1440,
        "UnHealthyThreshold": 2880
      }
    }
  },
  "AllowedHosts": "*",
  "CorsOrigins": [
    "https://isldevldsadmin.azurewebsites.net",
    "https://localhost:44405"
  ],
  "blobStorage": {
    "azureBlobServiceUri": "https://sadldevdigitalteam.blob.core.windows.net",
    "azureTenantId": "2f7a9b80-2e65-4ed6-9851-2f727effb3a1",
    "blobContainers": {
      "emislanding": "emislanding",
      "versioner": "versioner",
      "ingress": "ingress",
      "optOut": "optOut",
      "pds": "pds",
      "tpplanding": "tpplanding",
      "addresses": "addresses"
    }
  },
  "Features": [
    "Configuration",
    "OptOut",
    "IngestionTracking",
    "IngestionTrackingSearch",
    "Pds",
    "TerminologyArtifact",
    "SubscriberAgreement",
    "Address",
    "ResolvedAddress"
  ],
  "landingSettings": {
    "landingSupplierId": "67680f17-9d0c-4474-8b35-56ca8f9df1f6",
    "encryptedFolder": "encrypted",
    "decryptedFolder": "inbox",
    "keyVaultUrl": "https://kv-dev-digital-team.vault.azure.net/"
  },
  "ftpDownload": {
    "ftpServer": "",
    "ftpPort": "1231",
    "ftpPassword": "",
    "ftpUserName": "",
    "ftpKey": "",
    "ftpPassPhrase": ""
  },
  "IDecide": {
    "hashPepper": "pepper",
    "folderName": "localdataoptout",
    "filePrefix": "ldoo"
  },
  "UseOfflineProvider": false,
  "ReleaseVersion":  "v0.2.0.1"
