{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2022",
    "allowJs": true,
    "checkJs": false,
    "jsx": "react",
    "outDir": "./build",
    "rootDir": "./src",
    "removeComments": true,
    "noEmit": true,
    "pretty": true,
    "skipLibCheck": true,
    "strict": true,
    "moduleResolution": "node",
    "esModuleInterop": true
  },
  "include": [ "src/**/*" ],
  "exclude": [ "node_modules", "**/*.test.tsx", "aspnetcore*.js" ]
}